# Automatically includes Linux, Node.js, and npm pre-installed
FROM node:20-alpine AS builder

# create a user with permissions to run the app
# -S -> create a system user
# -G add the user to a group
# This is done to avoid running the app as root
# If the app is run as root, any vulnerabilities in the app could be exploited to gain
# access to the host system
# It's a good practice to run the app as a non-root user

run addgroup app && adduser -S app -G app 

# set the user to run the app
USER app

# set the working directory to /app
WORKDIR /app

COPY package*.json ./

# copy the package.json and package-lock.json files to the working directory
# and thus the app can't access the files and throws  an error-> EACCES: permission
# denied. to avoid this, change the ownership of the files to the root user
### USER root


# sometimes the ownership of the /app directory to the app user
# chown -r <user>:<group> <directory>
# ch(base) rodney@GarnettSilk:~/src/docker/helloreact$ which vite
### own command changes the user and/or group ownership of for given ffile.
### RUN chown -R app:app .

#change the user back gto the app user
USER app  

# install dpendencies
 RUN npm install

# copy the rest of the application code to the working directory
COPY . .

# build the app for production
CMD npm run dev

# Switch to a new lightweight Nginx image
FROM nginx:alpine

# Copy the built files from the develope stage (build)
# to the Nginx html directory. This copies the production-ready
# static files generated by the build proess.
COPY --from=build /app/build /usr/share/nginx/html

# expose(base) rodney@GarnettSilk:~/src/docker/helloreact$ which vite
# port 5173 to tell Docker that the container listens on the specified network
# ports at runtime.

EXPOSE 80
###  EXPOSE 5173

# command to run the app continously in the foreground. This is necessary for Docker to keep the container running.

 CMD ["nginx", "-g", "daemon off;"]

# CMD npm run dev
### CMD ["npm", "run", "dev", "--", "--host"]